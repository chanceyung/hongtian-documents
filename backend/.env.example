# ============================================
# 杂志级文档重构智能体 V4 — 后端环境变量
# ============================================

# ---- GLM-5 API（必填） ----
# 智谱 AI API 密钥，用于文档分析和设计建议
CUSTOM_LLM_API_KEY=your_zhipu_api_key_here

# ---- 素材补充（可选） ----
# Pexels 免费图片库 API 密钥
PEXELS_API_KEY=
# Unsplash 免费图片库访问令牌
UNSPLASH_ACCESS_KEY=
# Replicate AI 图片生成 API 令牌
REPLICATE_API_TOKEN=

# ---- 应用配置 ----
# 是否开启调试模式（生产环境设为 false）
DEBUG=false
# 数据库连接字符串
DATABASE_URL=sqlite:///./app_data/magazine.db
# Redis 连接字符串（用于任务队列和缓存）
REDIS_URL=redis://redis:6379/0

# ---- 文件存储路径 ----
# 用户上传文件存储目录
UPLOAD_DIR=./data/uploads
# 生成文件输出目录
OUTPUT_DIR=./data/output
# 素材文件存储目录
ASSETS_DIR=./data/assets
# 模板文件目录
TEMPLATE_DIR=./app/templates

# ---- LLM 配置 ----
# LLM 类型（custom 表示使用自定义 API）
LLM=custom
# 自定义 LLM API 地址
CUSTOM_LLM_URL=https://open.bigmodel.cn/api/paas/v4
# 使用的模型名称
CUSTOM_MODEL=glm-4-flash

# ---- 保真校验 ----
# 保真相似度阈值（0.0-1.0，默认 0.95）
FIDELITY_THRESHOLD=0.95
# 最大修复尝试次数
MAX_REPAIR_ATTEMPTS=2

# ---- 安全配置 ----
# API 密钥加密密钥（必须至少 16 字节，生产环境请更换默认值）
API_KEY_ENCRYPTION_KEY=change-me-in-production-32byte
# 最大上传文件大小（MB）
MAX_UPLOAD_SIZE_MB=100

# CORS origins (JSON array format)
CORS_ORIGINS=['http://localhost:3000','http://localhost:8000']
